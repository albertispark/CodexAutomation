# Copy to .env.local (gitignored). Keep real secrets out of tracked files.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional gateway/proxy routing.
# ANTHROPIC_BASE_URL=https://your-gateway.example.com
# OPENAI_BASE_URL=https://your-openai-compatible-gateway.example.com/v1

# Optional Ollama/config overrides.
# OLLAMA_HOST=http://localhost:11434
# PIPELINE_CONFIG=/path/to/settings.yaml

# Recommended server-side setting. This is NOT read from this .env file.
# On macOS, run the following and then restart Ollama.app:
#   launchctl setenv OLLAMA_MAX_LOADED_MODELS 1
# OLLAMA_MAX_LOADED_MODELS=1
